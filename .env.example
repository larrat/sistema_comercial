# =============================================================================
# Sistema Comercial — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite .env.local ou qualquer arquivo com valores reais.
# =============================================================================

# ── Supabase (Frontend) ──────────────────────────────────────────────────────
# URL do projeto Supabase (visível no painel: Settings > API)
SC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxx.supabase.co

# Chave anon/public do Supabase (segura para expor no cliente — controlada por RLS)
SC_SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase Edge Functions ──────────────────────────────────────────────────
# ATENÇÃO: estas variáveis SÃO SECRETAS — configurar via Supabase Dashboard
#          Settings > Edge Functions > Secrets. NUNCA colocar no código.

# Service Role Key (acesso total ao banco — usado apenas em Edge Functions)
# SUPABASE_SERVICE_ROLE_KEY=sb_service_xxxxxxxx   ← configurar no painel, não aqui

# URL de redirecionamento pós-convite (usada por acessos-admin-convite)
# APP_INVITE_REDIRECT_TO=https://seudominio.com/login

# ── Configurações opcionais de runtime ──────────────────────────────────────
# Timeout de requests em ms (padrão: 12000)
# SC_REQ_TIMEOUT_MS=12000

# Máximo de retries em falhas recuperáveis (padrão: 2)
# SC_RETRY_MAX=2

# Base de tempo entre retries em ms (padrão: 250)
# SC_RETRY_BASE_MS=250

# ── Ambiente de desenvolvimento ──────────────────────────────────────────────
# Habilita defaults legados (uso interno apenas — NUNCA em produção)
# SC_ALLOW_LEGACY_SUPABASE_DEFAULTS=false

# Ativa avisos de configuração ausente no console
# SC_WARN_CONFIG=true

# ── Checklist de segurança ───────────────────────────────────────────────────
# [ ] SC_SUPABASE_URL configurado via window.__SC_SUPABASE_URL__ ou runtime-config.js
# [ ] SC_SUPABASE_KEY configurado via window.__SC_SUPABASE_KEY__ ou runtime-config.js
# [ ] SUPABASE_SERVICE_ROLE_KEY configurado SOMENTE no painel de Edge Functions
# [ ] APP_INVITE_REDIRECT_TO configurado no painel de Edge Functions
# [ ] 01b_rls_anon_dev.sql NUNCA executado em produção
# [ ] RLS ativo em todas as tabelas (validar com 05b_validacao_fase_1_rls_rbac.sql)
# [ ] Supabase CLI migrations configurado (supabase/migrations/)
