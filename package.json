{
  "name": "sistema-comercial",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "typecheck:strict": "tsc --project tsconfig.strict.json --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui-core": "playwright test tests/e2e/login.spec.js tests/e2e/setup-filial.spec.js tests/e2e/bootstrap-filial.spec.js",
    "test:e2e:onda-b": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke/run-fase-2-ui-core.ps1",
    "test:e2e:fase-2": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke/run-fase-2-suite.ps1",
    "test:e2e:login": "playwright test tests/e2e/login.spec.js",
    "test:e2e:setup-filial": "playwright test tests/e2e/setup-filial.spec.js",
    "test:e2e:bootstrap-filial": "playwright test tests/e2e/bootstrap-filial.spec.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.53.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
